{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "TrackSuite.work",
    "version": "0.9.2",
    "identifier": "com.tracksuite-work.desktop",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://localhost:5173",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "TrackSuite.work",
                "width": 1280,
                "height": 800,
                "minWidth": 1024,
                "minHeight": 680
            }
        ]
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "createUpdaterArtifacts": true,
        "linux": {
            "deb": {
                "files": {
                    "/usr/share/metainfo/com.tracksuite.work.desktop.metainfo.xml": "../../packaging/linux/com.tracksuite.work.desktop.deb.metainfo.xml"
                }
            }
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico",
            "icons/icon.png"
        ],
        "category": "Productivity",
        "shortDescription": "Cross-platform work time tracking desktop app"
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2MUM0NzBCQzM4MkY3MTIKUldRUzk0TERDMGNjWmx6eU9GRmFSRFZTbUlacTBETHMxMzJrL200S1FrK1Z3Z045aUNFVWxmSDQK",
            "endpoints": [
                "https://github.com/julianquandt/TrackSuite.work/releases/latest/download/latest.json"
            ]
        }
    }
}